export default async function handler(req, res) {
  const url = req.query.url;

  if (!url) {
    return res.status(400).json({
      error: "URL required"
    });
  }

  try {
    const response = await fetch(
      url.startsWith("http")
        ? url
        : `https://${url}`
    );

    return res.status(200).json({
      online: true,
      status: response.status
    });

  } catch (error) {

    return res.status(200).json({
      online: false
    });

  }
}
